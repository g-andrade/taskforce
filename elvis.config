% -*- mode: erlang; -*- vim: set ft=erlang:
[
    {config, [
        #{
            files => ["src/**/*.erl"],
            ruleset => erl_files,
            rules => [
                % `tf_minion_serv` deliberately uses `catch`: once to run an
                % arbitrary user task function and capture whatever it returns
                % or raises as the task result, and once to treat the master's
                % death during `gen_server:call/2` as a normal stop. Both turn
                % any outcome into a value rather than letting it propagate.
                {elvis_style, no_catch_expressions, #{ignore => [tf_minion_serv]}}
            ]
        },
        #{
            files => ["test/**/*.erl"],
            ruleset => erl_files,
            rules => [
                {elvis_style, no_debug_call, disable},
                {elvis_style, no_receive_without_timeout, disable},
                {elvis_style, dont_repeat_yourself, disable}
            ]
        },
        #{
            files => ["rebar.config", "elvis.config"],
            ruleset => rebar_config
        }
    ]}
].
